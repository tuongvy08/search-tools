# Sao chép thành file .env và điền giá trị thật (không commit file .env)

# --- Trên máy (dev) ---
# Có thể dùng Docker: trong thư mục project chạy `docker compose up -d`
# rồi dùng DATABASE_URL bên dưới (DB riêng, không đụng Vultr).
# DATABASE_URL=postgresql://searchlocal:searchlocal@127.0.0.1:5432/products_local

# --- PostgreSQL — bắt buộc khi chạy app ---
# Production (Vultr): chỉ điền khi bạn sẵn sàng deploy; giữ file .env chỉ trên server.
DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/ten_database

# Flask session (đổi thành chuỗi ngẫu nhiên dài trên production)
FLASK_SECRET_KEY=doi-mat-khau-session

# Cổng Flask (mặc định trong code: 5001 — tránh xung đột với dịch vụ khác trên 5000)
PORT=5001

# Mật khẩu đăng nhập kiểu cũ (chỉ mật khẩu, để trống username trên form)
APP_PASSWORD_MANAGER=mat-khau-manager
APP_PASSWORD_STAFF=mat-khau-staff
# Team áp dụng cho tài khoản staff kiểu cũ (phải khớp teams.id và đã seed team_brands)
# LEGACY_STAFF_TEAM_ID=1

# Tạo admin đầu tiên (chạy bootstrap_admin.py)
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=

# Tuỳ chọn: đường dẫn stub middleware (log), mặc định giống server cũ
# ACCESS_CONTROL_BASE_PATH=/home/deploy/myapps

# --- Giới hạn IP văn phòng (tuỳ chọn) ---
# Trên máy dev: bật để không bị chặn
# DISABLE_IP_ALLOWLIST=1
# Trên Vultr: tắt (không đặt hoặc =0). Cho phép nhiều IP/CIDR, cách nhau bởi dấu phẩy:
# OFFICE_IP_ALLOWLIST=203.0.113.10,192.0.2.0/24
# Có thể bổ sung / sửa IP qua trang admin /admin/network (bảng office_ip_allowlist) sau khi chạy sql/migration_006_office_ip_allowlist.sql
